{
  "name": "@vanrot/ui",
  "version": "0.1.1",
  "description": "Accessible UI primitives and design tokens for Vanrot.",
  "keywords": [
    "vanrot",
    "ui",
    "components"
  ],
  "license": "MIT",
  "author": "Fendy Haddad",
  "homepage": "https://github.com/FendyHaddad/vanrot/tree/main/packages/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FendyHaddad/vanrot.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/FendyHaddad/vanrot/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "web-types": "./web-types.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/brand",
    "src/docs",
    "src/primitives",
    "src/styles",
    "src/tokens",
    "web-types.json"
  ],
  "dependencies": {
    "@vanrot/runtime": "file:../runtime"
  },
  "scripts": {
    "prebuild": "pnpm --filter @vanrot/runtime build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @vanrot/runtime build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @vanrot/runtime build",
    "test": "vitest run",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\""
  }
}
