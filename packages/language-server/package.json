{
  "name": "@vanrot/language-server",
  "version": "0.2.1",
  "description": "Language server providing editor intelligence for Vanrot templates.",
  "keywords": ["vanrot", "language-server", "lsp"],
  "license": "MIT",
  "author": "Fendy Haddad",
  "homepage": "https://github.com/FendyHaddad/vanrot/tree/main/packages/language-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FendyHaddad/vanrot.git",
    "directory": "packages/language-server"
  },
  "bugs": {
    "url": "https://github.com/FendyHaddad/vanrot/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vanrot-language-server": "./dist/bin/server.js",
    "vanrot-editor-intelligence": "./dist/bin/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@vanrot/compiler": "file:../compiler",
    "@vanrot/config": "file:../config",
    "typescript": "^6.0.3",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8"
  },
  "scripts": {
    "prebuild": "pnpm --filter @vanrot/compiler build && pnpm --filter @vanrot/config build",
    "build": "tsc -p tsconfig.json && node scripts/emit-globs.mjs",
    "build:intellij": "pnpm run build && node scripts/bundle-intellij.mjs",
    "pretypecheck": "pnpm --filter @vanrot/compiler build && pnpm --filter @vanrot/config build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => { rmSync('dist', { recursive: true, force: true }); rmSync('dist-intellij', { recursive: true, force: true }); })\""
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "esbuild": "^0.28.0",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
