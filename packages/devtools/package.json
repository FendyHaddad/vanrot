{
  "name": "@vanrot/devtools",
  "version": "0.1.0",
  "description": "Development-time tooling and diagnostics for Vanrot.",
  "keywords": ["vanrot", "devtools"],
  "license": "MIT",
  "author": "Fendy Haddad",
  "homepage": "https://github.com/FendyHaddad/vanrot/tree/main/packages/devtools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FendyHaddad/vanrot.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/FendyHaddad/vanrot/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\""
  },
  "devDependencies": {
    "@types/node": "^22.19.19"
  }
}
