{
  "name": "@vanrot/config",
  "version": "0.1.2",
  "description": "Shared configuration loading and types for Vanrot.",
  "keywords": [
    "vanrot",
    "config"
  ],
  "license": "MIT",
  "author": "Fendy Haddad",
  "homepage": "https://github.com/FendyHaddad/vanrot/tree/main/packages/config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FendyHaddad/vanrot.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/FendyHaddad/vanrot/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\""
  },
  "devDependencies": {
    "@types/node": "^22.19.19"
  }
}
