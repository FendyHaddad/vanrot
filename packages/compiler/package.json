{
  "name": "@vanrot/compiler",
  "version": "0.2.1",
  "description": "Template and component compiler for the Vanrot framework.",
  "keywords": [
    "vanrot",
    "compiler"
  ],
  "license": "MIT",
  "author": "Fendy Haddad",
  "homepage": "https://github.com/FendyHaddad/vanrot/tree/main/packages/compiler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FendyHaddad/vanrot.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/FendyHaddad/vanrot/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@vanrot/ui": "file:../ui",
    "parse5": "^7.1.2",
    "postcss": "^8.4.49",
    "postcss-selector-parser": "^6.1.2",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "prebuild": "pnpm --filter @vanrot/ui build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @vanrot/ui build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @vanrot/ui build",
    "test": "vitest run",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\""
  },
  "devDependencies": {
    "@types/node": "^22.19.19"
  }
}
