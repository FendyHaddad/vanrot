{
  "name": "@vanrot/cli",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "@vanrot/cli",
      "version": "0.0.0",
      "dependencies": {
        "@vanrot/config": "file:../config",
        "@vanrot/ui": "file:../ui"
      },
      "bin": {
        "vr": "dist/bin.js"
      }
    },
    "../config": {
      "name": "@vanrot/config",
      "version": "0.0.0",
      "dependencies": {
        "typescript": "^5.9.3"
      }
    },
    "../config/node_modules/typescript": {},
    "../runtime": {
      "name": "@vanrot/runtime",
      "version": "0.0.0"
    },
    "../ui": {
      "name": "@vanrot/ui",
      "version": "0.0.0",
      "dependencies": {
        "@vanrot/runtime": "file:../runtime"
      }
    },
    "../ui/node_modules/@vanrot/runtime": {
      "resolved": "../runtime",
      "link": true
    },
    "node_modules/@vanrot/config": {
      "resolved": "../config",
      "link": true
    },
    "node_modules/@vanrot/ui": {
      "resolved": "../ui",
      "link": true
    }
  }
}
