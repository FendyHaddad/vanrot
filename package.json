{
  "name": "vanrot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test && pnpm test:phase-docs",
    "test:phase-docs": "vitest run scripts/verify-phase-docs.test.mjs scripts/verify-site-docs.test.mjs scripts/verify-ai-docs.test.mjs",
    "audit:core": "vitest run --config vitest.audit.config.ts",
    "lint": "pnpm -r --if-present run lint",
    "clean": "pnpm -r --if-present run clean",
    "verify:phase-docs": "node scripts/verify-phase-docs.mjs",
    "verify:site-docs": "node scripts/verify-site-docs.mjs",
    "verify:ai-docs": "node scripts/verify-ai-docs.mjs",
    "verify:size": "pnpm --filter @vanrot/runtime size",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm verify:size && pnpm verify:site-docs && pnpm verify:ai-docs && pnpm verify:phase-docs"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^22.19.19",
    "jsdom": "^29.1.1",
    "size-limit": "^12.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
