{
  "name": "@vanrot/vanrot-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "web-types": "./web-types.json",
  "scripts": {
    "prepare:deps": "pnpm --filter @vanrot/config build && pnpm --filter @vanrot/runtime build && pnpm --filter @vanrot/behavior build && pnpm --filter @vanrot/router build && pnpm --filter @vanrot/ui build && pnpm --filter @vanrot/vite-plugin build && pnpm --filter @vanrot/cli build",
    "dev": "vr dev",
    "open:site": "node ../../scripts/open-docs.mjs",
    "open:docs": "node ../../scripts/open-docs.mjs docs",
    "docs:open": "node ../../scripts/open-docs.mjs docs",
    "prebuild": "pnpm run prepare:deps",
    "build": "node ../../packages/cli/dist/bin.js build",
    "pretest": "pnpm run prepare:deps",
    "test": "vitest run",
    "doctor": "vr doctor",
    "pretypecheck": "pnpm run prepare:deps",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "@vanrot/behavior": "file:../../packages/behavior",
    "@vanrot/config": "file:../../packages/config",
    "@vanrot/router": "file:../../packages/router",
    "@vanrot/runtime": "file:../../packages/runtime",
    "@vanrot/ui": "file:../../packages/ui"
  },
  "devDependencies": {
    "@vanrot/cli": "file:../../packages/cli",
    "@vanrot/vite-plugin": "file:../../packages/vite-plugin",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.14"
  }
}
